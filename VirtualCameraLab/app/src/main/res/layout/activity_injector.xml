<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="状态: 待机"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="16dp"
        android:background="#E3F2FD"/>

    <Button
        android:id="@+id/btn_start_inject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开始注入"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="注入参数调节"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <TextView android:id="@+id/tv_intensity" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="照射强度:19%"/>
    <SeekBar android:id="@+id/seek_intensity" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:max="100" android:progress="19"/>

    <TextView android:id="@+id/tv_diameter" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="照射直径:91%"/>
    <SeekBar android:id="@+id/seek_diameter" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:max="100" android:progress="91"/>

    <TextView android:id="@+id/tv_x" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="X坐标:47%"/>
    <SeekBar android:id="@+id/seek_x" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:max="100" android:progress="47"/>

    <TextView android:id="@+id/tv_y" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Y坐标:50%"/>
    <SeekBar android:id="@+id/seek_y" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:max="100" android:progress="50"/>
</LinearLayout>
