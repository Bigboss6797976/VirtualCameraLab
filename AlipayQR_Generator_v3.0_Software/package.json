{
  "name": "alipayqr-electron",
  "version": "3.0.0",
  "description": "AlipayQR Desktop App",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.alipayqr.app",
    "productName": "AlipayQR",
    "directories": { "output": "dist-electron" },
    "files": ["electron-main.js", "src/ui/web/**/*"],
    "win": { "target": "nsis", "icon": "assets/icons/icon.ico" },
    "mac": { "target": "dmg", "icon": "assets/icons/icon.icns" },
    "linux": { "target": "AppImage", "icon": "assets/icons" }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}